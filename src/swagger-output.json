                  },
                  "paymentMethod": {
                    "type": "string",
                    "enum": [
                      "esewa",
                      "khalti"
                    ]
                  },
                  "alternativePhone": {
                    "type": "string"
                  },
                  "screenshot": {
                    "type": "string",
